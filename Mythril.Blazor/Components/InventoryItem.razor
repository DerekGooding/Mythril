@using Mythril.Blazor.Services
@using Mythril.Data
@inject DragDropService DragDropService
@inject InventoryService InventoryService
@inject InventoryManager InventoryManager
@implements IDisposable

<div class="inventory-item @(showOverflowGlow ? "overflowing" : "") @(isAtMaxCapacity ? "at-capacity" : "") @(InventoryManager.IsPinned(Item.Item.Name) ? "pinned" : "")" 
     data-testid="inventory-item-@Item.Item.Name.Replace(" ", "-").ToLower()"
     draggable="true" 
     @ondragstart="HandleDragStart"
     @onclick:ctrlKey="TogglePin"
     title="@Item.Item.Name: @Item.Item.Description @(isAtMaxCapacity ? "(MAX)" : "")">
    
    <div class="item-icon-container">
        <ItemIcon Item="Item.Item" />
        @if (InventoryManager.IsPinned(Item.Item.Name))
        {
            <span class="pin-icon material-icons" data-testid="pin-icon">push_pin</span>
        }
    </div>

    <span class="item-quantity">@FormatQuantity(Item.Quantity)</span>

    @if (showAnimation)
    {
        <div class="floating-text @(quantityChange > 0 ? "positive" : "negative")">
            @(quantityChange > 0 ? "+" : "")@quantityChange
        </div>
    }
</div>

@code {
    [Parameter]
    public ItemQuantity Item { get; set; }

    private int previousQuantity;
    private int quantityChange;
    private bool showAnimation;
    private bool showOverflowGlow;

    private bool isAtMaxCapacity => Item.Item.ItemType == ItemType.Spell && Item.Quantity >= InventoryManager.MagicCapacity;

    protected override void OnInitialized()
    {
        InventoryService.OnItemOverflow += HandleOverflow;
    }

    private string FormatQuantity(int qty)
    {
        if (qty >= 1000000) return (qty / 1000000.0).ToString("0.#") + "M";
        if (qty >= 1000) return (qty / 1000.0).ToString("0.#") + "k";
        return qty.ToString();
    }

    private void TogglePin()
    {
        InventoryManager.TogglePin(Item.Item.Name);
        StateHasChanged();
    }

    private void HandleOverflow(string itemName)
    {
        if (Item.Item.Name == itemName)
        {
            showOverflowGlow = true;
            StateHasChanged();
            _ = Task.Delay(2000).ContinueWith(_ => 
            {
                showOverflowGlow = false;
                InvokeAsync(StateHasChanged);
            });
        }
    }

    public void Dispose()
    {
        InventoryService.OnItemOverflow -= HandleOverflow;
    }

    protected override void OnParametersSet()
    {
        if (previousQuantity != 0 && previousQuantity != Item.Quantity)
        {
            quantityChange = Item.Quantity - previousQuantity;
            showAnimation = true;
            StateHasChanged();
            _ = System.Threading.Tasks.Task.Delay(1000).ContinueWith(t =>
            {
                showAnimation = false;
                StateHasChanged();
            });
        }
        previousQuantity = Item.Quantity;
    }

    private void HandleDragStart(DragEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(Item.Item.Name))
        {
            args.DataTransfer.EffectAllowed = "move";
            DragDropService.Data = Item;
        }
    }
}
