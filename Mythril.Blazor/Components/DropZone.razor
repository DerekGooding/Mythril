@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Mythril.Data
@using Mythril.Blazor.Services
@inject DragDropService DragDropService
@inject IJSRuntime JS


<div class="drop-zone @Class @(isShaking ? "shake" : "")"
    @ondragover="HandleDragOver"
    @ondragover:preventDefault="true"
    @ondrop="HandleDrop"
    @ondragenter="HandleDragEnter"
    @ondragenter:preventDefault="true">
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else
    {
        <p class="m-0 small">@Message</p>
    }
</div>

@code {
    [Parameter]
    public string Class { get; set; } = "";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback<object> OnQuestDrop { get; set; }

    [Parameter]
    public EventCallback<object> OnDropFailed { get; set; }

    [Parameter]
    public Func<object, bool>? Accepts { get; set; }

    [Parameter]
    public string Message { get; set; } = "Drop here to assign";

    private bool isShaking = false;

    private void HandleDragEnter(DragEventArgs args)
    {
        if (IsValidDrop())
        {
            args.DataTransfer.DropEffect = "move";
        }
    }

    private void HandleDragOver(DragEventArgs args)
    {
        if (IsValidDrop())
        {
            args.DataTransfer.DropEffect = "move";
        }
    }

    private bool IsValidDrop()
    {
        var data = DragDropService.Data;
        if (data == null) return false;
        
        // Check if it's one of our accepted types
        bool isCorrectType = data is QuestData || data is CadenceUnlock || data is Cadence || data is RefinementData;
        if (!isCorrectType) return false;

        // Check if the specific component accepts this instance
        if (Accepts != null)
        {
            return Accepts(data);
        }

        return true;
    }

    private async Task HandleDrop()
    {
        if (IsValidDrop())
        {
            await OnQuestDrop.InvokeAsync(DragDropService.Data);
        }
        else if (DragDropService.Data != null)
        {
            await Shake();
            if (OnDropFailed.HasDelegate)
            {
                await OnDropFailed.InvokeAsync(DragDropService.Data);
            }
        }

        DragDropService.Data = null;
    }

    private async Task Shake()
    {
        isShaking = true;
        await System.Threading.Tasks.Task.Delay(500);
        isShaking = false;
    }
}
