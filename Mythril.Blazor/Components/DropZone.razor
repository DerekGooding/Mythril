@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Mythril.Data
@using Mythril.Blazor.Services
@inject DragDropService DragDropService
@inject IJSRuntime JS


<div class="drop-zone @(isShaking ? "shake" : "")"
    @ondragover="HandleDragOver"
    @ondrop="HandleDrop"
    @ondragenter="HandleDragEnter">
    <p class="m-0 small">@Message</p>
</div>

@code {
    [Parameter]
    public EventCallback<object> OnQuestDrop { get; set; }

    [Parameter]
    public Func<object, bool>? Accepts { get; set; }

    [Parameter]
    public string Message { get; set; } = "Drop here to assign.";

    private bool isShaking = false;

    private async Task HandleDragEnter(DragEventArgs args)
    {
        if (IsValidDrop())
        {
            args.DataTransfer.DropEffect = "move";
        }
    }

    private async Task HandleDragOver(DragEventArgs args)
    {
        if (IsValidDrop())
        {
            args.DataTransfer.DropEffect = "move";
        }
    }

    private bool IsValidDrop()
    {
        var data = DragDropService.Data;
        if (data == null) return false;
        
        // Check if it's one of our accepted types
        bool isCorrectType = data is QuestData || data is CadenceUnlock || data is Cadence;
        if (!isCorrectType) return false;

        // Check if the specific component accepts this instance
        if (Accepts != null)
        {
            return Accepts(data);
        }

        return true;
    }

    private async Task HandleDrop()
    {
        if (IsValidDrop())
        {
            await OnQuestDrop.InvokeAsync(DragDropService.Data);
        }
        else if (DragDropService.Data != null)
        {
            await Shake();
        }

        DragDropService.Data = null;
    }

    private async Task Shake()
    {
        isShaking = true;
        await System.Threading.Tasks.Task.Delay(500);
        isShaking = false;
    }
}
