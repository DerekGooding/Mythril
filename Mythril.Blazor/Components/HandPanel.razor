@using Mythril.Data

@inject ResourceManager ResourceManager

<div class="hand-panel">
    <div class="hand-header">
        <h3>Available Quests</h3>
    </div>

    <div class="hand-content">
        @if (Locations is not null)
        {
            @foreach (var location in Locations.Where(l => l.Quests.Any()))
            {
                var stats = GetCompletionStats(location);
                <Expander Header="@location.Name" 
                          @key="@location.Name"
                          CompletedCount="@stats.Completed"
                          TotalCount="@stats.Total">
                    @{
                        var sortedQuests = location.Quests
                            .OrderBy(q => ResourceManager.GetQuestDetails(q).Type == QuestType.Recurring)
                            .ToList();
                    }
                    @foreach (var quest in sortedQuests)
                    {
                        <div class="task-container" @key="@quest.Name">
                            <QuestCard QuestData="@QuestToData(quest)" />
                        </div>
                    }
                </Expander>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public List<LocationData>? Locations { get; set; }

    public QuestData QuestToData(Quest quest) => new QuestData(quest, ResourceManager.GetQuestDetails(quest));

    private (int Completed, int Total) GetCompletionStats(LocationData location)
    {
        var oneTimeQuests = location.AllQuests.Where(q => 
        {
            var detail = ResourceManager.GetQuestDetails(q);
            return detail.Type == QuestType.Single || detail.Type == QuestType.Unlock;
        }).ToList();

        if (!oneTimeQuests.Any()) return (0, 0);

        var completed = oneTimeQuests.Count(q => ResourceManager.GetCompletedQuests().Contains(q));
        return (completed, oneTimeQuests.Count);
    }
}
