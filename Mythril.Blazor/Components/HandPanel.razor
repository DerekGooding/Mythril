@using Mythril.Data

@inject ResourceManager ResourceManager

<div class="hand-panel">
    <div class="hand-content">
        @if (Locations is not null)
        {
            @foreach (var location in Locations.Where(l => l.Quests.Any()))
            {
                <Expander Header="@location.Name" @key="@location.Name">
                    @foreach (var quest in location.Quests)
                    {
                        <div class="task-container" @key="@quest.Name">
                            <QuestCard QuestData="@QuestToData(quest)" />
                        </div>
                    }
                </Expander>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public List<LocationData>? Locations { get; set; }

    public QuestData QuestToData(Quest quest) => new QuestData(quest, ResourceManager.GetQuestDetails(quest));
}
