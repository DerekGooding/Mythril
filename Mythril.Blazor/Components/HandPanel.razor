@using Mythril.Data

@inject ResourceManager ResourceManager

<div class="hand-panel">
    <div class="hand-controls p-2 d-flex justify-content-end">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="sortDuration" data-testid="sort-duration-switch" @bind="_sortByDuration" />
            <label class="form-check-label small ms-1" for="sortDuration">Sort by Duration</label>
        </div>
    </div>
    <div class="hand-content">
        @if (Locations is not null)
        {
            @foreach (var location in Locations.Where(l => l.Quests.Any()))
            {
                var stats = GetCompletionStats(location);
                bool isActive = IsLocationActive(location);
                <Expander Header="@location.Name" 
                          @key="@location.Name"
                          Type="@GetLocationType(location)"
                          IsActive="@isActive"
                          IsUnseen="@ResourceManager.HasUnseenContent(location)"
                          CompletedCount="@stats.Completed"
                          TotalCount="@stats.Total"
                          OnToggle="@(() => ResourceManager.MarkLocationAsSeen(location))">
                    @{
                        var quests = location.Quests.ToList();
                        var sortedQuests = _sortByDuration 
                            ? quests.OrderBy(q => ResourceManager.GetQuestDetails(q).DurationSeconds).ToList()
                            : quests.OrderBy(q => ResourceManager.GetQuestDetails(q).Type == QuestType.Recurring).ToList();
                    }
                    @foreach (var quest in sortedQuests)
                    {
                        <div class="task-container" @key="@quest.Name">
                            <QuestCard QuestData="@QuestToData(quest)" />
                        </div>
                    }
                </Expander>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public List<LocationData>? Locations { get; set; }

    private bool _sortByDuration;

    public QuestData QuestToData(Quest quest) => new QuestData(quest, ResourceManager.GetQuestDetails(quest));

    private string GetLocationType(LocationData data)
    {
        // Find the original location record to get its Type
        var original = ResourceManager.GetLocation(data.Name);
        return original.Type ?? "Plains";
    }

    private bool IsLocationActive(LocationData data)
    {
        var activeQuestNames = ResourceManager.ActiveQuests.Select(q => q.Name).ToHashSet();
        return data.Quests.Any(q => activeQuestNames.Contains(q.Name));
    }

    private (int Completed, int Total) GetCompletionStats(LocationData location)
    {
        var oneTimeQuests = location.AllQuests.Where(q => 
        {
            var detail = ResourceManager.GetQuestDetails(q);
            return detail.Type == QuestType.Single || detail.Type == QuestType.Unlock;
        }).ToList();

        if (!oneTimeQuests.Any()) return (0, 0);

        var completed = oneTimeQuests.Count(q => ResourceManager.GetCompletedQuests().Contains(q));
        return (completed, oneTimeQuests.Count);
    }
}
