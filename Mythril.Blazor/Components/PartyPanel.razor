@using Mythril.Data
@inject Mythril.Data.ResourceManager resourceManager

<div class="party-panel d-flex flex-column h-100 overflow-hidden">
    <h3 class="flex-shrink-0">Party</h3>
    <div class="d-flex flex-column flex-grow-1 overflow-auto gap-2">
        @if (Party is not null && QuestProgresses is not null)
        {
            @foreach (var character in Party)
            {
                <CharacterDisplay @key="character.Name"
                                    Character="character"
                                    QuestProgresses="QuestProgresses.Where(p => p.Character.Name == character.Name)"
                                    OnQuestDrop="(task) => OnQuestDrop.InvokeAsync((task, character))"
                                    OnCompletionAnimationEnd="(progress) => OnCompletionAnimationEnd.InvokeAsync(progress)"
                                    Accepts="Accepts"
                                    OnUnequip="OnUnequip" />
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<Character> Party { get; set; } = [];

    [Parameter]
    public List<QuestProgress>? QuestProgresses { get; set; }

    [Parameter]
    public EventCallback<(object, Character)> OnQuestDrop { get; set; }

    [Parameter]
    public EventCallback<QuestProgress> OnCompletionAnimationEnd { get; set; }

    [Parameter]
    public EventCallback<Cadence> OnUnequip { get; set; }

    [Parameter]
    public Func<object, bool>? Accepts { get; set; }
}
