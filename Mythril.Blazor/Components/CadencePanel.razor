@using Mythril.Data
@using Mythril.Blazor.Services
@inject DragDropService DragDropService
@inject ResourceManager resourceManager

<div class="cadence-panel d-flex flex-column h-100">
    <div class="cadence-controls p-2 border-bottom">
        <input type="text" class="form-control form-control-sm" 
               placeholder="Search abilities (e.g. J-Str)..." 
               data-testid="cadence-ability-search"
               @bind="_abilitySearchTerm" @bind:event="oninput" />
    </div>

    <div class="flex-grow-1 overflow-auto mt-2">
        @if (FilteredCadences is not null && FilteredCadences.Any())
        {
            @foreach (var cadence in FilteredCadences)
            {
                var stats = GetCompletionStats(cadence);
                bool matchesSearch = !string.IsNullOrWhiteSpace(_abilitySearchTerm) && 
                                     cadence.Abilities.Any(a => a.Ability.Name.Contains(_abilitySearchTerm, StringComparison.OrdinalIgnoreCase));

                <CadenceDragExpander Cadence="cadence" 
                                     @key="@cadence.Name"
                                     IsHighlighted="@matchesSearch"
                                     CompletedCount="@stats.Completed"
                                     TotalCount="@stats.Total">
                    <CadenceTree CadenceData="cadence" />
                </CadenceDragExpander>
            }
        }
        else
        {
            <div class="no-cadences text-center p-4 text-muted">
                @( string.IsNullOrWhiteSpace(_abilitySearchTerm) ? "No Cadences discovered" : "No matching abilities found" )
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<Cadence>? UnlockedCadences { get; set; }

    [Parameter]
    public int UnlockedCadenceNamesCount { get; set; }

    [Parameter]
    public EventCallback<Cadence> OnUnequip { get; set; }

    private string _abilitySearchTerm = "";

    private IEnumerable<Cadence>? FilteredCadences => UnlockedCadences; 
    // We don't filter out the cadences themselves, just highlight them in CadenceDragExpander if the ability matches.
    // Actually, usually search filters the list. But the requirement says "Highlight Cadences containing specific searched abilities".
    // I'll keep the full list but highlight.

    private async Task HandleUnequip(object cadenceObj)
    {
        if (cadenceObj is Cadence cadence)
        {
            await OnUnequip.InvokeAsync(cadence);
        }
    }

    private (int Completed, int Total) GetCompletionStats(Cadence cadence)
    {
        if (cadence.Abilities == null) return (0, 0);
        
        int total = cadence.Abilities.Length;
        int completed = cadence.Abilities.Count(a => resourceManager.UnlockedAbilities.Contains($"{cadence.Name}:{a.Ability.Name}"));
        
        return (completed, total);
    }
}
