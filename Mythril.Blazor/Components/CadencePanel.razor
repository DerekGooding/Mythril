@using Mythril.Data
@using Mythril.Blazor.Services
@inject DragDropService DragDropService

<div class="hand-panel d-flex flex-column h-100">
    <div class="flex-shrink-0 d-flex justify-content-between align-items-center">
        <h3>Cadence Progression</h3>
        @if (DragDropService.Data is Cadence)
        {
            <div class="unequip-zone alert alert-danger py-1 px-3 mb-0 animate-pulse">
                <DropZone OnQuestDrop="HandleUnequip" Accepts="(obj) => obj is Cadence">
                    Drop here to Unequip
                </DropZone>
            </div>
        }
    </div>

    <div class="flex-grow-1 overflow-auto mt-2">
        @if (UnlockedCadences is not null && UnlockedCadences.Any())
        {
            @foreach (var cadence in UnlockedCadences)
            {
                <CadenceDragExpander Cadence="cadence" @key="@cadence.Name">
                    <CadenceTree CadenceData="cadence" />
                </CadenceDragExpander>
            }
        }
        else
        {
            <div class="alert alert-warning">
                No Cadences Unlocked. Unlocked names count: @UnlockedCadenceNamesCount
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<Cadence>? UnlockedCadences { get; set; }

    [Parameter]
    public int UnlockedCadenceNamesCount { get; set; }

    [Parameter]
    public EventCallback<Cadence> OnUnequip { get; set; }

    private async Task HandleUnequip(object cadenceObj)
    {
        if (cadenceObj is Cadence cadence)
        {
            await OnUnequip.InvokeAsync(cadence);
        }
    }
}
