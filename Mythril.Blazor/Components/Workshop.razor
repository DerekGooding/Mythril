@using Mythril.Data
@using Mythril.Blazor.Services
@inject ResourceManager resourceManager
@inject ItemRefinements refinements
@inject SnackbarService SnackbarService

<div class="workshop-panel">
    <div class="workshop-header">
        <h3>Item Refinement Workshop</h3>
        <p>Drag refinement tasks onto characters with the required abilities.</p>
    </div>

    <div class="workshop-content">
        @{
            var discoveredRefinements = refinements.ByKey
                .Where(r => resourceManager.UnlockedAbilities.Any(ua => ua.EndsWith($":{r.Key.Name}")))
                .ToList();
        }

        @if (discoveredRefinements.Any())
        {
            @foreach (var refinementGroup in discoveredRefinements)
            {
                var ability = refinementGroup.Key;
                // Check if ANY character has a cadence assigned that has this ability UNLOCKED
                var anyoneHasAbility = resourceManager.Characters.Any(c => resourceManager.HasAbility(c, ability));
                
                <div @key="ability.Name" class="refinement-group @(anyoneHasAbility ? "" : "locked")">
                    <h4>@ability.Name @(anyoneHasAbility ? "" : "(Assign a character with this ability to unlock)")</h4>
                    
                    <div class="recipe-list">
                        @foreach (var recipeKvp in refinementGroup.Value)
                        {
                            var inputItem = recipeKvp.Key;
                            var recipe = recipeKvp.Value;
                            var refinementData = new RefinementData(ability, inputItem, recipe);
                            
                            <RefinementCard Refinement="@refinementData" @key="@(ability.Name + inputItem.Name)" />
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-refinements">
                No refinements discovered
            </div>
        }
    </div>
</div>

@code {
    // Methods removed as refinements are now handled via StartQuest in Home.razor
}
