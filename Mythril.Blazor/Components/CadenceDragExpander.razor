@using Mythril.Blazor.Services
@using Microsoft.JSInterop
@inject DragDropService DragDropService

<div class="expander">
    <div class="expander-header" @onclick="Toggle">
        <div class="inventory-item" draggable="true" @ondragstart="HandleDragStart" @onclick:stopPropagation="true">
            <span class="item-name">@Cadence.Name</span>
        </div>
        <span class="expander-icon @(isExpanded ? "expanded" : "")">▼</span>
    </div>
    <div class="expander-content @(isExpanded ? "open" : "closed")">
        @ChildContent
    </div>
</div>

@code {
    [Parameter]
    public Cadence Cadence { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool isExpanded = false;

    private void Toggle()
    {
        isExpanded = !isExpanded;
    }

    private void HandleDragStart(DragEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(Cadence.Name))
        {
            args.DataTransfer.EffectAllowed = "move";
            DragDropService.Data = Cadence;
        }
    }
}
