@using Microsoft.AspNetCore.Components.Web
@using Mythril.Data
@using Mythril.Blazor
@using Mythril.Blazor.Services
@inject DragDropService DragDropService
@inject ResourceManager ResourceManager

@{
    bool inProgress = ResourceManager.IsInProgress(Unlock);
    string abilityKey = $"{Unlock.CadenceName}:{Unlock.Ability.Name}";
    bool isHighlighted = ResourceManager.HighlightedPath.Contains(abilityKey);
}

<div class="card @(inProgress ? "locked" : "") @(isHighlighted ? "prerequisite-highlight" : "")" 
     draggable="@(inProgress ? "false" : "true")" 
     @ondragstart="HandleDragStart"
     @onmouseenter="() => ResourceManager.HighlightPath(abilityKey)"
     @onmouseleave="() => ResourceManager.ClearHighlight()">
    <div class="card-header d-flex align-items-center">
        @Unlock.Ability.Name
        @if (inProgress)
        {
            <span class="active-dot pulse ms-2" title="Active Task In Progress"></span>
            <span class="ms-auto badge bg-warning text-dark small">In Progress</span>
        }
    </div>
    <div class="card-content">
        <div class="card-main">
            <p>@Unlock.Ability.Description</p>
        </div>
        <div class="card-side">
            <ul>
                <li class="text-info">
                    <span title="Stat used to improve task time">⚡</span> <strong>@Unlock.PrimaryStat</strong>
                </li>
                @if (Unlock.Requirements is not null && Unlock.Requirements.Length > 0)
                {
                    @foreach (var requirement in Unlock.Requirements)
                    {
                        <li @key="requirement">
                            <span title="Item Requirement">📦</span> @requirement.Item.Name @requirement.Quantity
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public CadenceUnlock Unlock { get; set; }

    private void HandleDragStart(DragEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(Unlock.Ability.Name))
        {
            args.DataTransfer.EffectAllowed = "move";
            DragDropService.Data = Unlock;
        }
    }
}
