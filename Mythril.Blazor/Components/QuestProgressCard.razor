@using Microsoft.JSInterop
@using Mythril.Data
@using System.Globalization
@inject IJSRuntime JS

<div class="task-progress-card" @ref="cardElement">
    <div class="d-flex justify-content-between align-items-center">
        <div class="task-header text-truncate">@QuestProgress?.Name</div>
        <div class="task-duration text-nowrap small text-muted">
            @if (QuestProgress?.SecondsElapsed < 0)
            {
                <span class="fst-italic text-info">Preparing next cycle...</span>
            }
            else
            {
                <span>@QuestProgress?.DurationSeconds s</span>
            }
        </div>
    </div>
    <div class="task-body">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <p class="small mb-0 text-muted text-truncate">@QuestProgress?.Description</p>
            @if (QuestProgress?.QuestData?.PrimaryStat != null)
            {
                <span class="badge bg-light text-dark border small ms-1" title="Stat used to improve task time">⚡ @QuestProgress.QuestData.PrimaryStat</span>
            }
        </div>
        <div class="progress">
            @{
                var progressValue = QuestProgress?.Progress ?? 0.0;
                if (double.IsNaN(progressValue) || double.IsInfinity(progressValue)) progressValue = 0.0;
                var progressPercent = Math.Clamp(progressValue * 100, 0, 100);
                var progressStyle = $"width: {progressPercent.ToString("0.##", CultureInfo.InvariantCulture)}%";
                var isPreparing = QuestProgress?.SecondsElapsed < 0;
            }
            
            @if (isPreparing)
            {
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-secondary" 
                     role="progressbar" 
                     style="width: 100%">
                </div>
            }
            else
            {
                <div class="progress-bar" 
                     role="progressbar" 
                     style="@progressStyle" 
                     aria-valuenow="@progressPercent" 
                     aria-valuemin="0" aria-valuemax="100">
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public QuestProgress? QuestProgress { get; set; }

    [Parameter]
    public EventCallback OnCompletionAnimationEnd { get; set; }

    private ElementReference cardElement;

    private bool _hasTriggeredCompletion = false;
    private QuestProgress? _lastQuestProgress;

    protected override async Task OnParametersSetAsync()
    {
        if (QuestProgress != _lastQuestProgress)
        {
            _hasTriggeredCompletion = false;
            _lastQuestProgress = QuestProgress;
        }

        if (QuestProgress?.IsCompleted == true && !_hasTriggeredCompletion)
        {
            _hasTriggeredCompletion = true;
            await Task.Delay(1000); 
            await OnCompletionAnimationEnd.InvokeAsync();
        }
    }
}
