@using Microsoft.AspNetCore.Components.Web
@using Mythril.Data
@using Mythril.Blazor
@using Mythril.Blazor.Services
@inject DragDropService DragDropService
@inject ResourceManager ResourceManager

@{
    bool inProgress = (QuestData!.Type == QuestType.Single || QuestData.Type == QuestType.Unlock) && ResourceManager.IsInProgress(QuestData);
    bool isHighlighted = ResourceManager.HighlightedPath.Contains(QuestData.Name);
}

<div class="card @(inProgress ? "locked" : "") @(isHighlighted ? "prerequisite-highlight" : "")" 
     draggable="@(inProgress ? "false" : "true")" 
     @ondragstart="HandleDragStart"
     @onmouseenter="() => ResourceManager.HighlightPath(QuestData.Name)"
     @onmouseleave="() => ResourceManager.ClearHighlight()">
    <div class="card-header">
        <span class="material-icons" style="color: green;">
            @(QuestData!.Type == QuestType.Single ? "flag" : "repeat")
        </span>
        @QuestData.Name
        @if (ResourceManager.IsCompleted(QuestData.Name))
        {
            <span class="ms-1 text-success material-icons" style="font-size: 1rem;" title="Completed at least once">check_circle</span>
        }
        @if (inProgress)
        {
            <span class="ms-auto badge bg-warning text-dark small">In Progress</span>
        }
    </div>

    <div class="card-content">
        <div class="card-main">
            <p>@QuestData.Description</p>
            <p>@QuestData.DurationSeconds s <span class="text-info small ms-2" title="Stat used to improve task time">⚡ @QuestData.PrimaryStat</span></p>
        </div>
        <div class="card-side">
            @{
                var forwardUnlocks = ResourceManager.GetForwardUnlocks(QuestData.Quest);
                bool isCompleted = ResourceManager.IsCompleted(QuestData.Name);
            }
            @if (QuestData.Requirements.Length > 0 || (QuestData.RequiredStats != null && QuestData.RequiredStats.Count > 0) || (forwardUnlocks.Count > 0 && !isCompleted))
            {
                <ul>
                    @if (!isCompleted)
                    {
                        @foreach (var unlock in forwardUnlocks)
                        {
                            <li @key="unlock" class="text-warning">
                                <span title="Unlocks">✨</span> @unlock
                            </li>
                        }
                    }
                    @foreach (var requirement in QuestData.Requirements)
                    {
                        var hasEnough = ResourceManager.Inventory.GetQuantity(requirement.Item) >= requirement.Quantity;
                        <li @key="requirement" class="@(hasEnough ? "" : "low-resource")" title="@(hasEnough ? "" : $"Missing {requirement.Quantity - ResourceManager.Inventory.GetQuantity(requirement.Item)} units")">
                            <span title="Item Requirement">📦</span> @requirement.Item.Name @requirement.Quantity
                        </li>
                    }
                    @if (QuestData.RequiredStats != null)
                    {
                        @foreach (var statReq in QuestData.RequiredStats)
                        {
                            var currentStatValue = ResourceManager.JunctionManager.GetStatValue(ResourceManager.Characters[0], statReq.Key);
                            var meetsStat = currentStatValue >= statReq.Value;
                            <li @key="statReq.Key" class="stat-requirement text-info @(meetsStat ? "" : "low-stat")" title="@(meetsStat ? "" : $"Need {statReq.Value - currentStatValue} more {statReq.Key}")">
                                <span title="Stat Requirement">🛡️</span> <strong>@statReq.Key: @statReq.Value</strong>
                            </li>
                        }
                    }
                </ul>
            }
        </div>
        <div class="card-side">
            @if (QuestData.Rewards.Length > 0)
            {
                <ul class="text-success">
                    @foreach (var reward in QuestData.Rewards)
                    {
                        <li @key="reward"><span title="Reward">💎</span> @reward.Item.Name @reward.Quantity</li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public QuestData? QuestData { get; set; }

    private void HandleDragStart(DragEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(QuestData!.Name))
        {
            args.DataTransfer.EffectAllowed = "move";
            DragDropService.Data = QuestData;
        }
    }
}
