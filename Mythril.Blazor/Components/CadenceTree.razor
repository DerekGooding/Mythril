@using Mythril.Data
@inject ResourceManager resourceManager

<div class="cadence-tree">
    @foreach (var abilityUnlock in CadenceData.Abilities)
    {
        var isUnlocked = resourceManager.UnlockedAbilities.Contains(abilityUnlock.Ability);
        var canAfford = resourceManager.CanAfford(abilityUnlock);
        var stateClass = isUnlocked ? "unlocked" : canAfford ? "affordable" : "locked";

        <div @key="abilityUnlock" class="ability-node @stateClass">
            <div class="ability-card-wrapper">
                <AbilityUnlockCard Unlock="abilityUnlock" />
            </div>
            
            @if (!isUnlocked)
            {
                <div class="unlock-action">
                    <DropZone_cadence OnCharacterDrop="(c) => resourceManager.StartQuest(abilityUnlock, c)"
                                       Accepts="(c) => resourceManager.CanAfford(abilityUnlock)">
                        <div class="drop-target @(canAfford ? "active" : "")">
                            <span class="material-icons-outlined">person_add</span>
                            <small>Drag Hero Here</small>
                        </div>
                    </DropZone_cadence>
                </div>
            }
            else
            {
                <div class="unlock-status">
                    <span class="material-icons text-success">check_circle</span>
                    <small>Unlocked</small>
                </div>
            }
        </div>
    }
</div>

<style>
    .cadence-tree {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 1rem;
    }

    .ability-node {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.5rem;
        border-radius: 12px;
        background-color: var(--tab-inactive-bg);
        border: 1px solid var(--border-color);
        transition: transform 0.2s;
    }

    .ability-node:hover {
        transform: translateX(5px);
    }

    .ability-card-wrapper {
        flex: 1;
        min-width: 0;
    }

    .unlock-action, .unlock-status {
        width: 120px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ability-node.unlocked {
        border-color: var(--unlocked-border);
        background-color: rgba(40, 167, 69, 0.05);
    }

    .ability-node.affordable {
        border-color: var(--affordable-border);
    }

    .drop-target {
        border: 2px dashed var(--drop-zone-border);
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        border-radius: 8px;
        color: var(--text-muted);
        transition: all 0.2s;
        width: 100%;
    }

    .drop-target.active {
        border-color: var(--primary-color);
        color: var(--primary-color);
        background-color: rgba(187, 134, 252, 0.1);
    }

    .drop-target:hover {
        background-color: var(--badge-bg);
    }
</style>

@code {
    [Parameter]
    public Cadence CadenceData { get; set; }

    private string GetTooltip(CadenceUnlock unlock)
    {
        var reqs = string.Join("\n", unlock.Requirements.Select(r => $"- {r.Quantity} {r.Item.Name}"));
        return "Requirements:\n" + reqs;
    }
}
