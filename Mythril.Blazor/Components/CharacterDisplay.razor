@using Mythril.Data
@using Mythril.Blazor.Services
@using System.Globalization
@inject Stats statsContent
@inject ResourceManager resourceManager
@inject JunctionManager JunctionManager
@inject DragDropService DragDropService

<div class="character-display shadow-theme @(QuestProgress is not null ? "has-active-task" : "") @(QuestProgress?.IsCompleted == true ? "completed" : "") d-flex align-items-center gap-2">
    @{
        var assignedCadences = JunctionManager.CurrentlyAssigned(Character).ToList();
    }
    
    @if (assignedCadences.Any() || (QuestProgress is not null && !QuestProgress.IsCompleted))
    {
        <div class="character-controls d-flex flex-column gap-1">
            @if (assignedCadences.Any())
            {
                <button class="btn btn-xs btn-outline-primary" data-testid="junction-toggle" @onclick="ToggleJunctionMenu">Junction</button>
                
                @if (resourceManager.CanAutoQuest(Character))
                {
                    var isAuto = resourceManager.IsAutoQuestEnabled(Character);
                    <button class="btn btn-xs @(isAuto ? "btn-success" : "btn-outline-secondary")" 
                            data-testid="autoquest-toggle"
                            @onclick="ToggleAutoQuest">
                        Auto: @(isAuto ? "ON" : "OFF")
                    </button>
                }
            }

            @if (QuestProgress is not null && !QuestProgress.IsCompleted)
            {
                <button class="btn btn-xs btn-outline-warning" 
                        data-testid="cancel-quest"
                        @onclick="CancelQuest">
                    Cancel
                </button>
            }
        </div>
    }

    <div class="flex-grow-1 min-width-0">
        <div class="character-header">
            <div class="d-flex flex-column flex-grow-1 min-width-0">
                <h4 class="character-name text-truncate">@Character.Name</h4>
                <div class="cadence-info small text-muted">
                    @if (assignedCadences.Any())
                    {
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var cadence in assignedCadences)
                            {
                                <div class="badge bg-secondary d-flex align-items-center gap-1">
                                    <span class="text-truncate" style="max-width: 80px;">@cadence.Name</span>
                                    <button class="btn btn-xs p-0 text-white" @onclick="() => OnUnequip.InvokeAsync(cadence)" title="Unequip">&times;</button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <span>Cadence: None</span>
                    }
                </div>
            </div>
            <div class="stats-container">
                <div class="stats-mini">
                    @foreach (var stat in statsContent.All)
                    {
                        var val = JunctionManager.GetStatValue(Character, stat.Name);
                        var junction = JunctionManager.Junctions.FirstOrDefault(j => j.Character.Name == Character.Name && j.Stat.Name == stat.Name);
                        
                        <span @key="stat.Name" class="stat-badge @(junction != null ? "junctioned" : "")" title="@stat.Description @(junction != null ? $"(J: {junction.Magic.Name})" : "")">
                            @stat.Name[0]: @val
                        </span>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-2">
            <div class="flex-grow-1">
                @if (QuestProgress is not null)
                {
                    <QuestProgressCard QuestProgress="QuestProgress" OnCompletionAnimationEnd="() => OnCompletionAnimationEnd.InvokeAsync(QuestProgress)" />
                }
                else
                {
                    <DropZone OnQuestDrop="HandleTaskDrop" Accepts="Accepts" />
                }
            </div>
        </div>
    </div>
    
    @if (QuestProgress is not null)
    {
        <div class="character-card-progress">
            @{
                var progressValue = QuestProgress.Progress;
                if (double.IsNaN(progressValue) || double.IsInfinity(progressValue)) progressValue = 0.0;
                var progressPercent = Math.Clamp(progressValue * 100, 0, 100);
                var progressStyle = $"width: {progressPercent.ToString("0.##", CultureInfo.InvariantCulture)}%";
            }
            <div class="progress-bar" style="@progressStyle"></div>
        </div>
    }

    @if (_showJunctionMenu)
    {
        <div class="junction-menu card p-2">
            <h6>Junction Magic</h6>
            <div class="junction-grid">
                @foreach (var stat in statsContent.All)
                {
                    bool canJunction = CanJunction(stat);
                    var currentJ = JunctionManager.Junctions.FirstOrDefault(j => j.Character.Name == Character.Name && j.Stat.Name == stat.Name);
                    
                    <div @key="stat.Name" class="junction-row d-flex justify-content-between align-items-center mb-1">
                        <span class="small @(canJunction ? "" : "text-muted")">@stat.Name</span>
                        @if (canJunction)
                        {
                            <select class="form-select form-select-sm w-auto" data-testid="junction-select" @onchange="(e) => HandleJunctionChange(stat, e)">
                                <option value="">None</option>
                                @foreach (var spell in resourceManager.Inventory.GetSpells())
                                {
                                    <option @key="spell.Item.Name" value="@spell.Item.Name" selected="@(currentJ?.Magic.Name == spell.Item.Name)">
                                        @spell.Item.Name (@spell.Quantity)
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark small">Locked</span>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Character Character { get; set; }

    [Parameter]
    public QuestProgress? QuestProgress { get; set; }

    [Parameter]
    public EventCallback<object> OnQuestDrop { get; set; }

    [Parameter]
    public Func<object, bool>? Accepts { get; set; }

    [Parameter]
    public EventCallback<QuestProgress> OnCompletionAnimationEnd { get; set; }

    [Parameter]
    public EventCallback<Cadence> OnUnequip { get; set; }

    private bool _showJunctionMenu = false;

    private void ToggleJunctionMenu() => _showJunctionMenu = !_showJunctionMenu;

    private void ToggleAutoQuest()
    {
        resourceManager.SetAutoQuestEnabled(Character, !resourceManager.IsAutoQuestEnabled(Character));
    }

    private void CancelQuest()
    {
        if (QuestProgress != null)
        {
            resourceManager.CancelQuest(QuestProgress);
        }
    }

    private bool CanJunction(Stat stat)
    {
        var assigned = JunctionManager.CurrentlyAssigned(Character);
        
        string abilityName = "J-" + stat.Name;
        if (stat.Name == "Vitality") abilityName = "J-Vit";
        if (stat.Name == "Strength") abilityName = "J-Str";
        if (stat.Name == "Speed") abilityName = "J-Speed";
        if (stat.Name == "Magic") abilityName = "J-Magic";

        return assigned.Any(c => c.Abilities.Any(a => a.Ability.Name == abilityName && resourceManager.UnlockedAbilities.Contains($"{c.Name}:{a.Ability.Name}")));
    }

    private void HandleJunctionChange(Stat stat, ChangeEventArgs e)
    {
        string magicName = e.Value?.ToString() ?? "";
        var magic = resourceManager.Inventory.GetSpells().FirstOrDefault(s => s.Item.Name == magicName).Item;
        JunctionManager.JunctionMagic(Character, stat, magic, resourceManager.UnlockedAbilities);
        StateHasChanged();
    }

    private void HandleTaskDrop(object task)
    {
        OnQuestDrop.InvokeAsync(task);
    }
}
