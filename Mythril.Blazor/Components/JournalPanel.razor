@using Mythril.Data
@inject ResourceManager ResourceManager
@implements IDisposable

<div class="journal-panel" data-testid="journal-panel">
    <div class="journal-controls mb-3 px-2">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="firstTimeFilter" @bind="_showFirstTimeOnly">
            <label class="form-check-label small" for="firstTimeFilter">Show First Time Only</label>
        </div>
    </div>

    @if (FilteredJournal.Any())
    {
        <div class="journal-entries">
            @foreach (var entry in FilteredJournal)
            {
                <div @key="entry" class="journal-entry mb-2 p-2 border rounded shadow-sm">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-center">
                            <h6 class="mb-1 me-2">@entry.TaskName</h6>
                            @if (entry.IsFirstTime)
                            {
                                <span class="badge bg-warning text-dark x-small">First Time</span>
                            }
                        </div>
                        <span class="small text-muted">@entry.CompletedAt.ToString("HH:mm:ss")</span>
                    </div>
                    <div class="entry-details small">
                        <span class="badge bg-info text-dark me-1">@entry.CharacterName</span>
                        <span>@entry.Details</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-entries text-center p-4 text-muted">
            <span class="material-icons mb-2 d-block">history</span>
            @( _showFirstTimeOnly ? "No first-time tasks completed yet." : "No tasks completed yet." )
        </div>
    }
</div>

<style>
    .x-small {
        font-size: 0.65rem;
        padding: 0.2em 0.5em;
    }
</style>

@code {
    private bool _showFirstTimeOnly;

    private IEnumerable<JournalEntry> FilteredJournal =>
        _showFirstTimeOnly ? ResourceManager.Journal.Where(j => j.IsFirstTime) : ResourceManager.Journal;
    protected override void OnInitialized()
    {
        ResourceManager.OnJournalUpdated += HandleJournalUpdated;
    }

    private void HandleJournalUpdated()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ResourceManager.OnJournalUpdated -= HandleJournalUpdated;
    }
}
