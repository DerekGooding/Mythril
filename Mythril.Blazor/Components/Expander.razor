@using Microsoft.JSInterop

<div class="expander">
    <div class="expander-header" @onclick="Toggle">
        <div class="d-flex align-items-center gap-2 flex-grow-1">
            <span>@Header</span>
            @if (TotalCount > 0)
            {
                <span class="completion-counter small text-muted">(@CompletedCount/@TotalCount)</span>
                @if (CompletedCount >= TotalCount)
                {
                    <span class="text-success small">✔</span>
                }
            }
        </div>
        <span class="expander-icon @(isExpanded ? "expanded" : "")">▼</span>
    </div>
    <div class="expander-content @(isExpanded ? "open" : "closed")">
        <div class="expander-inner">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Header { get; set; }

    [Parameter]
    public int CompletedCount { get; set; }

    [Parameter]
    public int TotalCount { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool isExpanded = false;

    private void Toggle()
    {
        isExpanded = !isExpanded;
    }
}
