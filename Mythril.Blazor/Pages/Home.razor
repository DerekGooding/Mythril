@page "/"
@using Mythril.Blazor.Services
@using Mythril.Data
@using System.Threading.Tasks

<PageTitle>Mythril</PageTitle>

<div class="container-fluid d-flex flex-column p-0 overflow-hidden" 
     tabindex="0" 
     @onkeydown="HandleGlobalKeyDown"
     style="outline: none;">
    
    @if (_showHelp)
    {
        <div class="help-overlay shadow-lg" @onclick="() => _showHelp = false">
            <div class="help-content p-4" @onclick:stopPropagation="true">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>Mythril Help</h3>
                    <button class="btn-close" @onclick="() => _showHelp = false"></button>
                </div>
                
                <section class="mb-4">
                    <h5>⌨️ Keyboard Shortcuts</h5>
                    <ul class="list-unstyled">
                        <li><kbd>1</kbd> - Locations</li>
                        <li><kbd>2</kbd> - Cadences</li>
                        <li><kbd>3</kbd> - Workshop</li>
                        <li><kbd>?</kbd> - Toggle Help</li>
                    </ul>
                </section>

                <section class="mb-4">
                    <h5>⛓️ Junction System</h5>
                    <p class="small">Assign a <strong>Cadence</strong> to a character to unlock Stat Junctions. Drag <strong>Magic</strong> from your inventory onto a Stat Badge to increase that attribute.</p>
                    <code>Stat = Base(10) + (Quantity * Modifier / 100)</code>
                </section>

                <section>
                    <h5>🤖 Automation</h5>
                    <p class="small">Unlock the <strong>AutoQuest</strong> ability in the Recruit cadence to allow characters to automatically repeat tasks when completed.</p>
                </section>

                <div class="mt-4 text-center">
                    <button class="btn btn-primary" @onclick="() => _showHelp = false">Got it!</button>
                </div>
            </div>
        </div>
    }

    <!-- Header Row -->
    <div class="header-row flex-shrink-0 p-2 d-flex align-items-center gap-3">
        <div class="d-flex flex-column gap-1">
            <button class="btn btn-sm btn-primary" data-testid="theme-toggle" @onclick="ToggleTheme">Toggle Theme</button>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-danger" data-testid="reset-game" @onclick="ResetGame">Reset Game</button>
                @if (resourceManager is not null)
                {
                    <span class="game-timer badge bg-dark text-light border border-secondary" title="Total Play Time">
                        🕒 @resourceManager.CurrentTimeFormatted
                    </span>
                }
            </div>
            @if (AuthService.IsAuthenticated)
            {
                <button class="btn btn-sm @(resourceManager!.IsTestMode ? "btn-warning" : "btn-outline-secondary")" 
                        data-testid="test-mode-toggle"
                        @onclick="ToggleTestMode">
                    Test Mode: @(resourceManager.IsTestMode ? "ON" : "OFF")
                </button>
            }
        </div>
        
        <div class="flex-grow-1 d-flex align-items-center gap-2">
            @if (resourceManager is not null)
            {
                <InventoryPanel Items="resourceManager.Inventory?.GetItems().ToList()" 
                                Spells="resourceManager.Inventory?.GetSpells().ToList()" />
            }
            
            <div class="version-stack d-flex flex-column align-items-end ms-auto text-nowrap">
                <span class="version-text small text-muted" style="cursor: pointer; user-select: none;" @onclick="OnVersionClick">
                    v: @(VersionService.CurrentVersion?.Substring(0, 7) ?? "local")
                </span>
                @if (VersionService.IsUpdateAvailable)
                {
                    <button class="btn btn-xs btn-warning animate-pulse mt-1" data-testid="update-button" @onclick="RefreshPage">
                        Update Available
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Main Content Area: Two Columns -->
    <div class="row flex-grow-1 min-height-0 m-0 overflow-hidden">
        <!-- Left column with tabs -->
        <div class="col-8 p-2 border-end">
            @if (resourceManager is not null)
            {
                <ul class="nav nav-tabs flex-shrink-0" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(resourceManager.ActiveTab == "hand" ? "active" : "")" id="hand-tab" data-testid="locations-tab" data-bs-toggle="tab" data-bs-target="#hand" type="button" role="tab" @onclick="MarkLocationsAsSeen">
                            Locations
                            @if (resourceManager.HasAnyUnseenLocation && resourceManager.ActiveTab != "hand")
                            {
                                <span class="notification-dot"></span>
                            }
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(resourceManager.ActiveTab == "cadence" ? "active" : "")" id="cadence-tab" data-testid="cadence-tab" data-bs-toggle="tab" data-bs-target="#cadence" type="button" role="tab" @onclick="MarkCadencesAsSeen">
                            Cadence
                            @if ((resourceManager.HasAnyUnseenCadence || resourceManager.HasUnseenCadence) && resourceManager.ActiveTab != "cadence")
                            {
                                <span class="notification-dot"></span>
                            }
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(resourceManager.ActiveTab == "workshop" ? "active" : "")" id="workshop-tab" data-testid="workshop-tab" data-bs-toggle="tab" data-bs-target="#workshop" type="button" role="tab" @onclick="MarkWorkshopAsSeen">
                            Workshop
                            @if (resourceManager.HasUnseenWorkshop && resourceManager.ActiveTab != "workshop")
                            {
                                <span class="notification-dot"></span>
                            }
                        </button>
                    </li>
                </ul>
                <div class="tab-content border border-top-0">
                    <div class="tab-pane @(resourceManager.ActiveTab == "hand" ? "active" : "")" id="hand" role="tabpanel">
                        <HandPanel Locations="resourceManager.UsableLocations" />
                    </div>
                    <div class="tab-pane @(resourceManager.ActiveTab == "cadence" ? "active" : "")" id="cadence" role="tabpanel">
                        <CadencePanel UnlockedCadences="resourceManager.UnlockedCadences" 
                                      UnlockedCadenceNamesCount="resourceManager.UnlockedCadenceNames.Count"
                                      OnUnequip="UnassignCadence" />
                    </div>
                    <div class="tab-pane @(resourceManager.ActiveTab == "workshop" ? "active" : "")" id="workshop" role="tabpanel">
                        <Workshop UnlockedAbilities="resourceManager.UnlockedAbilities" @key="@resourceManager.UnlockedAbilities.Count" />
                    </div>
                </div>
            }
            else
            {
                <p><em>Loading...</em></p>
            }
        </div>

        <!-- Right column with PartyPanel (Vertical listing) -->
        <div class="col-4 p-2 party-column">
            @if (resourceManager is not null)
            {
                <PartyPanel Party="resourceManager.Characters"
                            QuestProgresses="resourceManager.ActiveQuests"
                            OnQuestDrop="EventCallback.Factory.Create<(object, Character)>(this, TaskDropped)"
                            OnCompletionAnimationEnd="EventCallback.Factory.Create<QuestProgress>(this, OnCompletionAnimationEnd)"
                            Accepts="(item) => resourceManager.CanAfford(item)"
                            OnUnequip="UnassignCadence" />
            }
            else
            {
                <p><em>Loading...</em></p>
            }
        </div>
    </div>
</div>
